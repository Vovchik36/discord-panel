<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Login</title>

<style>
body{
    margin:0;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#000,#1a001f);
    font-family:Arial;
    overflow:hidden;
}

.box{
    background:rgba(255,255,255,0.05);
    padding:30px;
    border-radius:16px;
    width:320px;
    backdrop-filter:blur(10px);
    box-shadow:0 0 30px rgba(255,0,150,0.3);
    animation:pop .6s ease;
}

@keyframes pop{
    from{transform:scale(0.8);opacity:0}
    to{transform:scale(1);opacity:1}
}

h2{
    color:#ff4fd8;
    text-align:center;
}

input{
    width:100%;
    padding:12px;
    margin-top:15px;
    border:none;
    border-radius:10px;
    background:#111;
    color:#fff;
}

button{
    width:100%;
    margin-top:15px;
    padding:12px;
    border:none;
    border-radius:10px;
    background:linear-gradient(90deg,#ff00aa,#7c3aed);
    color:white;
    font-weight:bold;
    cursor:pointer;
    transition:.2s;
}

button:hover{
    transform:scale(1.03);
}

.loader{
    position:fixed;
    width:100%;
    height:100%;
    background:#000;
    display:flex;
    justify-content:center;
    align-items:center;
    flex-direction:column;
    color:#ff4fd8;
    animation:fadeOut 2s forwards;
    animation-delay:1.5s;
}

.bar{
    width:200px;
    height:6px;
    background:#222;
    border-radius:10px;
    overflow:hidden;
    margin-top:10px;
}

.fill{
    width:0%;
    height:100%;
    background:#ff4fd8;
    animation:load 1.5s forwards;
}

@keyframes load{
    to{width:100%}
}

@keyframes fadeOut{
    to{opacity:0;visibility:hidden}
}
</style>

</head>
<body>

<div class="loader">
    <div>Загрузка кадровой системы...</div>
    <div class="bar"><div class="fill"></div></div>
</div>

<div class="box">
    <h2>Вход</h2>
    <form method="POST" action="/login">
        <input name="name" placeholder="Введите имя">
        <button>Войти</button>
    </form>
</div>

</body>
</html>