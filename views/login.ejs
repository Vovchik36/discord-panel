<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Вход</title>

<style>
body{
    margin:0;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#0b1020,#121a2a);
    font-family:Arial;
    overflow:hidden;
}

/* мягкое свечение */
body::before{
    content:"";
    position:absolute;
    width:200%;
    height:200%;
    background:radial-gradient(circle at 30% 30%, rgba(90,120,200,0.15), transparent 40%),
               radial-gradient(circle at 70% 70%, rgba(120,90,200,0.12), transparent 45%);
    animation:move 14s infinite alternate ease-in-out;
}

@keyframes move{
    from{transform:translate(-5%,-5%)}
    to{transform:translate(5%,5%)}
}

.box{
    position:relative;
    width:340px;
    padding:28px;
    border-radius:16px;
    background:rgba(18,22,35,0.85);
    backdrop-filter:blur(12px);
    box-shadow:0 10px 30px rgba(0,0,0,0.6);
    text-align:center;
    animation:fade .5s ease;
    border:1px solid rgba(120,140,200,0.15);
}

@keyframes fade{
    from{opacity:0; transform:translateY(12px)}
    to{opacity:1; transform:translateY(0)}
}

h2{
    color:#cfd8ff;
    font-weight:500;
    margin-bottom:6px;
}

.dev{
    font-size:12px;
    color:#8fa0c2;
    margin-bottom:18px;
}

button{
    width:100%;
    padding:12px;
    border:none;
    border-radius:12px;
    background:linear-gradient(90deg,#2c3e66,#3b4d7a);
    color:#e8ecff;
    font-weight:500;
    cursor:pointer;
    transition:.2s;
}

button:hover{
    transform:scale(1.03);
    background:linear-gradient(90deg,#344a7a,#415a92);
}

button:active{
    transform:scale(0.98);
}

.small{
    margin-top:12px;
    font-size:12px;
    color:#7f8fb3;
}
</style>

</head>
<body>

<div class="box">

<h2>Кадровая система</h2>
<div class="dev">Разработчик Vovchik</div>

<form method="POST" action="/login">
    <button onclick="clickSound()">Войти в систему</button>
</form>

<div class="small">Добро пожаловать</div>

</div>

<audio id="clickSound" src="https://www.soundjay.com/buttons/sounds/button-09.mp3"></audio>

<script>
function clickSound(){
    const audio = document.getElementById("clickSound");
    audio.volume = 0.25;
    audio.play();
}
</script>

</body>
</html>