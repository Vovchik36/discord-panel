<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Vovchik System</title>

<style>
body {
    margin:0;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background: radial-gradient(circle, #1b1f2a, #0f1115);
    font-family:Arial;
    color:white;
    overflow:hidden;
}

/* АНИМАЦИЯ ФОНА */
.glow {
    position:absolute;
    width:600px;
    height:600px;
    background: radial-gradient(circle, rgba(88,101,242,0.3), transparent 70%);
    filter: blur(60px);
    animation: float 6s ease-in-out infinite;
}

@keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-40px); }
    100% { transform: translateY(0px); }
}

/* КОНТЕЙНЕР */
.box {
    width:420px;
    background: rgba(23,26,33,0.85);
    backdrop-filter: blur(12px);
    padding:25px;
    border-radius:18px;
    text-align:center;
    z-index:2;
    position:relative;
    box-shadow:0 0 40px rgba(0,0,0,0.6);
}

/* ПЛАВАЮЩИЙ ТЕКСТ */
.title {
    font-size:22px;
    animation: textFloat 3s ease-in-out infinite;
}

@keyframes textFloat {
    0% { transform: translateY(0px); opacity:0.8; }
    50% { transform: translateY(-6px); opacity:1; }
    100% { transform: translateY(0px); opacity:0.8; }
}

button {
    width:100%;
    padding:12px;
    margin-top:15px;
    border:none;
    border-radius:10px;
    background:#5865f2;
    color:white;
    cursor:pointer;
    transition:0.3s;
}

button:hover {
    transform:scale(1.05);
}

/* ЗАГРУЗКА */
.loader {
    display:none;
    margin-top:15px;
}

.bar {
    width:100%;
    height:6px;
    background:#222633;
    border-radius:10px;
    overflow:hidden;
}

.bar div {
    width:0%;
    height:100%;
    background:#5865f2;
    animation: load 2s forwards;
}

@keyframes load {
    to { width:100%; }
}

.status {
    margin-top:10px;
    font-size:14px;
    opacity:0.8;
}

.footer {
    margin-top:15px;
    font-size:12px;
    opacity:0.6;
}
</style>
</head>

<body>

<div class="glow"></div>

<div class="box">

    <div class="title">Добро пожаловать в кадровый аудит</div>
    <p style="opacity:0.7;">Система управления персоналом</p>

    <form method="POST" action="/login" id="form">
        <button type="submit" onclick="start()">Войти</button>
    </form>

    <div class="loader" id="loader">
        <div class="bar"><div></div></div>
        <div class="status" id="status">Загрузка...</div>
    </div>

    <div class="footer">
        разработан Vovchik
    </div>

</div>

<script>
function start() {
    event.preventDefault();

    document.getElementById("loader").style.display = "block";

    setTimeout(() => {
        document.getElementById("status").innerText = "Проверка доступа...";
    }, 800);

    setTimeout(() => {
        document.getElementById("status").innerText = "Готово";
    }, 1600);

    setTimeout(() => {
        document.getElementById("form").submit();
    }, 2200);
}
</script>

</body>
</html>