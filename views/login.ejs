<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Вход</title>

<style>
body{
    margin:0;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#0b0c10,#11131a);
    font-family:Arial;
    overflow:hidden;
}

/* мягкий фон */
body::before{
    content:"";
    position:absolute;
    width:200%;
    height:200%;
    background:radial-gradient(circle,#3b3b4a33,#0000);
    animation:move 12s infinite alternate ease-in-out;
}

@keyframes move{
    from{transform:translate(-10%,-10%)}
    to{transform:translate(10%,10%)}
}

.box{
    position:relative;
    width:320px;
    padding:28px;
    border-radius:14px;
    background:rgba(20,22,28,0.85);
    backdrop-filter:blur(10px);
    box-shadow:0 0 20px rgba(0,0,0,0.6);
    text-align:center;
    animation:fade .5s ease;
}

@keyframes fade{
    from{opacity:0; transform:translateY(10px)}
    to{opacity:1; transform:translateY(0)}
}

h2{
    color:#d6d6d6;
    font-weight:500;
    margin-bottom:6px;
}

.dev{
    font-size:12px;
    color:#8a8a8a;
    margin-bottom:18px;
}

button{
    width:100%;
    padding:12px;
    border:none;
    border-radius:10px;
    background:#2a2f3a;
    color:#e6e6e6;
    font-weight:500;
    cursor:pointer;
    transition:.2s;
}

button:hover{
    background:#343a48;
    transform:scale(1.02);
}

button:active{
    transform:scale(0.98);
}

.small{
    margin-top:12px;
    font-size:12px;
    color:#777;
}
</style>

</head>
<body>

<div class="box">

<h2>Кадровая система</h2>
<div class="dev">Разработчик Vovchik</div>

<form method="POST" action="/login">
    <button onclick="clickSound()">Войти в систему</button>
</form>

<div class="small">Добро пожаловать</div>

</div>

<!-- спокойный звук -->
<audio id="clickSound" src="https://www.soundjay.com/buttons/sounds/button-09.mp3"></audio>

<script>
function clickSound(){
    const audio = document.getElementById("clickSound");
    audio.volume = 0.3;
    audio.play();
}
</script>

</body>
</html>