<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Panel</title>

<style>
body {
    margin:0;
    background: radial-gradient(circle, #1b1f2a, #0f1115);
    font-family:Arial;
    color:white;
    display:flex;
    justify-content:center;
}

.box {
    width:850px;
    margin-top:40px;
    background:#171a21;
    padding:20px;
    border-radius:18px;
}

input, select {
    width:100%;
    padding:12px;
    margin-top:10px;
    border:none;
    border-radius:10px;
    background:#222633;
    color:white;
}

button {
    width:100%;
    padding:12px;
    margin-top:10px;
    border:none;
    border-radius:10px;
    background:#5865f2;
    color:white;
    cursor:pointer;
}

.copy {
    background:#43b581;
}

.result {
    margin-top:15px;
    padding:12px;
    background:#0d0f14;
    border-radius:10px;
    white-space:pre-line;
}
</style>
</head>

<body>

<div class="box">

<h2>📋 Генератор шаблона</h2>

<input id="id1" placeholder="Discord ID 1 (123456)">
<input id="id2" placeholder="Discord ID 2 (123456)">

<select id="action">
    <option>Повышение</option>
    <option>Понижение</option>
    <option>Увольнение</option>
    <option>Назначение</option>
</select>

<select id="rank">
<% for(let i=1;i<=15;i++){ %>
<option><%= i %> ранг</option>
<% } %>
</select>

<input id="reason" placeholder="Причина">

<button onclick="gen()">Сгенерировать</button>
<button class="copy" onclick="copy()">Копировать</button>

<div class="result" id="out">Результат...</div>

</div>

<script>
function format(id) {
    if (!id) return "";
    id = id.trim();
    if (!id.startsWith("<@")) {
        return `<@${id}>`;
    }
    return id;
}

function gen() {
    const id1 = format(document.getElementById("id1").value);
    const id2 = format(document.getElementById("id2").value);

    const action = document.getElementById("action").value;
    const rank = document.getElementById("rank").value;
    const reason = document.getElementById("reason").value;

    const text =
`${id1}
${id2}
Действие: ${action}
Ранг: ${rank}
Причина: ${reason}`;

    document.getElementById("out").innerText = text;
}

function copy() {
    navigator.clipboard.writeText(document.getElementById("out").innerText);
    alert("Скопировано");
}
</script>

</body>
</html>