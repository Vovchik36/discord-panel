<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Panel</title>

<style>
body{
    margin:0;
    font-family:Arial;
    background:linear-gradient(135deg,#000,#1a001f);
    color:#fff;
    display:flex;
    justify-content:center;
}

.box{
    width:850px;
    margin:40px;
    background:rgba(255,255,255,0.05);
    padding:24px;
    border-radius:18px;
    backdrop-filter:blur(10px);
    box-shadow:0 0 30px rgba(255,0,150,0.2);
}

h2{
    color:#ff4fd8;
    text-align:center;
}

input,select{
    width:100%;
    padding:12px;
    margin-top:8px;
    border:none;
    border-radius:10px;
    background:#111;
    color:#fff;
    transition:.2s;
}

input:focus,select:focus{
    transform:scale(1.02);
    box-shadow:0 0 10px #ff4fd8;
}

button{
    width:100%;
    padding:12px;
    margin-top:10px;
    border:none;
    border-radius:10px;
    background:linear-gradient(90deg,#ff00aa,#7c3aed);
    color:#fff;
    font-weight:bold;
    cursor:pointer;
    transition:.2s;
}

button:hover{
    transform:scale(1.02);
}

#out{
    margin-top:15px;
    background:#111;
    padding:12px;
    border-radius:10px;
    white-space:pre-wrap;
}

.online{
    margin-top:20px;
    text-align:center;
    color:#00ff88;
}
</style>
</head>

<body>

<div class="box">

<h2>Кадровый аудит</h2>

<input id="id1" placeholder="Discord ID">
<input id="st1" placeholder="Static">
<input id="id2" placeholder="Discord ID (другой)">
<input id="st2" placeholder="Static (другой)">

<select id="action">
<option>Повышение</option>
<option>Понижение</option>
<option>Увольнение</option>
</select>

<input id="reason" placeholder="Причина">

<button onclick="gen()">Сгенерировать</button>
<button onclick="copy()">Копировать</button>

<div id="out"></div>

<div class="online">
🟢 Онлайн: <span id="onlineCount">0</span>
</div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
socket.on("online",(c)=>{
    onlineCount.textContent = c;
});

function gen(){
out.textContent =
`${id1.value} | ${st1.value}
${id2.value} | ${st2.value}

${action.value}
${reason.value}`;
}

function copy(){
navigator.clipboard.writeText(out.textContent);
alert("Скопировано!");
}
</script>

</body>
</html>