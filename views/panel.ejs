<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Static Panel</title>

<style>
body {
    margin:0;
    font-family:Arial;
    background:#0f1115;
    color:white;
    display:flex;
    justify-content:center;
}

.box {
    width:800px;
    margin-top:40px;
    background:#171a21;
    padding:20px;
    border-radius:15px;
}

input {
    width:100%;
    padding:12px;
    margin-top:10px;
    border:none;
    border-radius:10px;
    background:#11131a;
    color:white;
}

label {
    display:block;
    margin-top:8px;
    opacity:0.8;
    font-size:14px;
}

button {
    width:100%;
    padding:12px;
    margin-top:12px;
    border:none;
    border-radius:10px;
    background:#5865f2;
    color:white;
    cursor:pointer;
    transition:0.3s;
}

button:hover {
    transform:scale(1.02);
}

.copy {
    background:#2ecc71;
}

.result {
    margin-top:15px;
    padding:12px;
    background:#0d0f14;
    border-radius:10px;
    white-space:pre-line;
}

.loading {
    display:none;
    text-align:center;
    margin-top:10px;
    opacity:0.7;
}
</style>
</head>

<body>

<div class="box">

<h2>📋 Static System</h2>

<label>Discord ID 1 (свой)</label>
<input id="id1" placeholder="введи ID">

<label>
<input type="checkbox" id="save"> Запомнить мой ID
</label>

<label>Discord ID 2 (другой)</label>
<input id="id2" placeholder="введи ID">

<button onclick="gen()">Сгенерировать</button>

<div class="loading" id="load">⏳ Пожалуйста подождите...</div>

<button class="copy" onclick="copy()">Копировать</button>

<div class="result" id="out"></div>

</div>

<script>

// загрузка сохранённого ID
window.onload = function() {
    const saved = localStorage.getItem("id1");
    if(saved) {
        document.getElementById("id1").value = saved;
        document.getElementById("save").checked = true;
    }
}

function format(id) {
    if(!id) return "";
    id = id.trim();
    if(!id.startsWith("<@")) id = `<@${id}>`;
    return id + " | static";
}

function gen() {
    document.getElementById("load").style.display = "block";
    document.getElementById("out").innerText = "";

    setTimeout(() => {

        const id1Val = document.getElementById("id1").value;
        const id2Val = document.getElementById("id2").value;

        if(document.getElementById("save").checked) {
            localStorage.setItem("id1", id1Val);
        } else {
            localStorage.removeItem("id1");
        }

        let text = "";

        if(id1Val) text += format(id1Val) + "\n";
        if(id2Val) text += format(id2Val) + "\n";

        document.getElementById("out").innerText = text;

        document.getElementById("load").style.display = "none";

    }, 1000);
}

function copy() {
    navigator.clipboard.writeText(document.getElementById("out").innerText);
    alert("Скопировано");
}

</script>

</body>
</html>