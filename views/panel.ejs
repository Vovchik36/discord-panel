<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Кадровая система</title>

<style>
body{
    margin:0;
    font-family:Arial;
    background:linear-gradient(135deg,#0b1020,#121a2a);
    color:#fff;
    display:flex;
    justify-content:center;
}

.box{
    width:850px;
    margin:40px;
    background:rgba(18,22,35,0.88);
    padding:24px;
    border-radius:16px;
}

/* loading */
#loadingScreen{
    position:fixed;
    inset:0;
    background:#0b1020;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    z-index:999;
}

.bar{
    width:240px;
    height:6px;
    background:#1f2a44;
    border-radius:10px;
    overflow:hidden;
    margin-top:10px;
}

.fill{
    width:0%;
    height:100%;
    background:#4f6ef7;
    animation:load 2s forwards;
}

@keyframes load{
    to{width:100%}
}

.hidden{display:none;}

/* UI */
h2{text-align:center;color:#cfd8ff}

select,input,button{
    width:100%;
    padding:12px;
    margin-top:10px;
    border:none;
    border-radius:10px;
    background:#121a2a;
    color:#fff;
}

button{
    background:linear-gradient(90deg,#2c3e66,#3b4d7a);
    cursor:pointer;
}

/* checkbox row */
.row{
    display:flex;
    align-items:center;
    gap:8px;
    margin-top:8px;
    font-size:13px;
    color:#9fb3ff;
}

#out{
    margin-top:15px;
    background:#0f1525;
    padding:12px;
    border-radius:10px;
    white-space:pre-wrap;
}
</style>

</head>
<body>

<div id="loadingScreen">
    <div>Загрузка системы...</div>
    <div class="bar"><div class="fill"></div></div>
</div>

<div class="box hidden" id="app">

<h2>Кадровая система</h2>

<select id="section" onchange="switchForm()">
    <option value="">Выберите раздел</option>
    <option value="ka">Кадровый аудит</option>
    <option value="spec">Отчёт спецухи</option>
</select>

<!-- KA -->
<div id="kaForm" style="display:none">

<input id="id1" placeholder="Discord ID (свой)">
<div class="row">
<input type="checkbox" id="saveId1">
<span>Запомнить ID</span>
</div>

<input id="st1" placeholder="Static (свой)">
<div class="row">
<input type="checkbox" id="saveSt1">
<span>Запомнить Static</span>
</div>

<input id="id2" placeholder="Discord ID (другой)">
<input id="st2" placeholder="Static (другой)">

<select id="rank">
<option>1 ранг</option>
<option>2 ранг</option>
<option>3 ранг</option>
<option>4 ранг</option>
<option>5 ранг</option>
<option>6 ранг</option>
<option>7 ранг</option>
<option>8 ранг</option>
<option>9 ранг</option>
<option>10 ранг</option>
<option>11 ранг</option>
<option>12 ранг</option>
<option>13 ранг</option>
<option>14 ранг</option>
<option>15 ранг</option>
</select>

<select id="action">
<option>Повышение</option>
<option>Понижение</option>
<option>Увольнение</option>
<option>Назначение</option>
</select>

<input id="reason" placeholder="Причина">

<button onclick="gen()">Сгенерировать</button>

</div>

<!-- SPEC -->
<div id="specForm" style="display:none">

<input id="spec1" placeholder="Кто выдал (ID)">
<input id="spec2" placeholder="Кто получил (ID)">
<input id="spec3" placeholder="Ссылка на одобрение">
<input id="spec4" placeholder="Что получаете">
<input id="spec5" placeholder="Серийный номер">
<input id="spec6" placeholder="Скриншот">

<button onclick="gen()">Сгенерировать</button>

</div>

<div id="out"></div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
socket.on("online",(c)=> {});

/* loading */
setTimeout(()=>{
    loadingScreen.style.display="none";
    app.classList.remove("hidden");

    loadData();
},2000);

/* switch */
function switchForm(){
    kaForm.style.display = section.value==="ka" ? "block" : "none";
    specForm.style.display = section.value==="spec" ? "block" : "none";
}

/* SAVE / LOAD */
function loadData(){
    if(localStorage.getItem("id1")) id1.value = localStorage.getItem("id1");
    if(localStorage.getItem("st1")) st1.value = localStorage.getItem("st1");
}

id1.oninput = ()=> {
    if(saveId1.checked) localStorage.setItem("id1", id1.value);
};

st1.oninput = ()=> {
    if(saveSt1.checked) localStorage.setItem("st1", st1.value);
};

/* generate */
function gen(){

    if(section.value==="ka"){
        out.textContent =
`<@${id1.value}> | ${st1.value}
<@${id2.value}> | ${st2.value}

Ранг: ${rank.value}
Действие: ${action.value}
Причина: ${reason.value}`;
    }

    if(section.value==="spec"){
        out.textContent =
`<@${spec1.value}> | -
<@${spec2.value}> | -

Одобрение: ${spec3.value}
Что получаете: ${spec4.value}
Серийный номер: ${spec5.value}
Скриншот: ${spec6.value}`;
    }
}
</script>

</body>
</html>