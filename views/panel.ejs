<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Vovchik Panel</title>

<style>
body {
    margin:0;
    font-family:Arial;
    background: linear-gradient(135deg, #0f1115, #1a1d2a);
    color:white;
    display:flex;
    justify-content:center;
}

.container {
    width:850px;
    margin-top:40px;
    background:rgba(23,26,33,0.9);
    padding:25px;
    border-radius:18px;
    box-shadow:0 0 40px rgba(0,0,0,0.5);
}

h2 {
    text-align:center;
    margin-bottom:20px;
}

input, select {
    width:100%;
    padding:12px;
    margin-top:10px;
    border:none;
    border-radius:10px;
    background:#11131a;
    color:white;
}

button {
    width:100%;
    padding:12px;
    margin-top:15px;
    border:none;
    border-radius:10px;
    background:#5865f2;
    color:white;
    cursor:pointer;
    transition:0.3s;
}

button:hover {
    transform:scale(1.02);
}

.copy {
    background:#2ecc71;
}

.result {
    margin-top:15px;
    padding:12px;
    background:#0d0f14;
    border-radius:10px;
    white-space:pre-line;
    min-height:60px;
}

/* loading */
.loading {
    display:none;
    text-align:center;
    margin-top:10px;
    opacity:0.8;
}
</style>
</head>

<body>

<div class="container">

<h2>📋 Кадровая система</h2>

<input id="id1" placeholder="Discord ID 1 (свой / static)">
<input id="id2" placeholder="Discord ID 2 (кого меняешь)">

<select id="action">
    <option>Повышение</option>
    <option>Понижение</option>
    <option>Увольнение</option>
    <option>Назначение</option>
</select>

<select id="rank">
<% for(let i=1;i<=15;i++){ %>
<option><%= i %> ранг</option>
<% } %>
</select>

<input id="reason" placeholder="Причина">

<button onclick="gen()">Сгенерировать</button>

<div class="loading" id="loading">⏳ Пожалуйста подождите...</div>

<button class="copy" onclick="copyText()">Копировать</button>

<div class="result" id="out">Результат появится тут...</div>

</div>

<script>

function format(id) {
    if (!id) return "";

    id = id.trim();

    if (!id.startsWith("<@")) {
        id = `<@${id}>`;
    }

    return id + " | static";
}

function gen() {
    document.getElementById("loading").style.display = "block";
    document.getElementById("out").innerText = "";

    setTimeout(() => {

        const id1 = format(document.getElementById("id1").value);
        const id2 = format(document.getElementById("id2").value);

        const action = document.getElementById("action").value;
        const rank = document.getElementById("rank").value;
        const reason = document.getElementById("reason").value;

        const text =
`${id1}
${id2}
Действие: ${action}
Ранг: ${rank}
Причина: ${reason}`;

        document.getElementById("out").innerText = text;
        document.getElementById("loading").style.display = "none";

    }, 1200);
}

function copyText() {
    navigator.clipboard.writeText(document.getElementById("out").innerText);
    alert("Скопировано");
}

</script>

</body>
</html>