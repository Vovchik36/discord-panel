<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Discord Panel</title>

<style>
body {
    margin:0;
    font-family:Arial;
    background:#0f1115;
    color:white;
    display:flex;
    justify-content:center;
}

.box {
    width:850px;
    margin-top:40px;
    background:#171a21;
    padding:20px;
    border-radius:15px;
}

input {
    width:100%;
    padding:10px;
    margin-top:8px;
    border:none;
    border-radius:8px;
    background:#11131a;
    color:white;
}

label {
    margin-top:10px;
    display:block;
    opacity:0.8;
    font-size:14px;
}

.row {
    display:flex;
    align-items:center;
    gap:10px;
}

button {
    width:100%;
    padding:12px;
    margin-top:15px;
    border:none;
    border-radius:10px;
    background:#5865f2;
    color:white;
    cursor:pointer;
}

button:hover {
    opacity:0.9;
}

.copy {
    background:#2ecc71;
}

.result {
    margin-top:15px;
    background:#0d0f14;
    padding:12px;
    border-radius:10px;
    white-space:pre-line;
}

.small {
    font-size:12px;
    opacity:0.7;
}
</style>
</head>

<body>

<div class="box">

<h2>📋 Discord Panel</h2>

<!-- СВОЙ ID -->
<label>Discord ID (свой)</label>
<input id="id1">

<div class="row">
    <label class="small">
        <input type="checkbox" id="saveId"> Запомнить ID
    </label>

    <label class="small">
        <input type="checkbox" id="saveStatic"> Запомнить Static
    </label>
</div>

<label>Static (свой)</label>
<input id="static1">

<hr>

<!-- ВТОРОЙ -->
<label>Discord ID (другой)</label>
<input id="id2">

<label>Static (другой)</label>
<input id="static2">

<hr>

<label>Действие</label>
<input id="action">

<label>Ранг</label>
<input id="rank">

<label>Причина</label>
<input id="reason">

<button onclick="gen()">Сгенерировать</button>
<button class="copy" onclick="copyText()">Копировать</button>

<div class="result" id="out"></div>

</div>

<script>

// загрузка памяти
window.onload = () => {
    const id = localStorage.getItem("id1");
    const st = localStorage.getItem("static1");

    if(id) document.getElementById("id1").value = id;
    if(st) document.getElementById("static1").value = st;

    if(id) document.getElementById("saveId").checked = true;
    if(st) document.getElementById("saveStatic").checked = true;
};

function format(id, st) {
    if(!id || !st) return "";
    if(!id.startsWith("<@")) id = `<@${id}>`;
    return `${id} | ${st}`;
}

function gen() {

    let id1 = document.getElementById("id1").value.trim();
    let st1 = document.getElementById("static1").value.trim();

    let id2 = document.getElementById("id2").value.trim();
    let st2 = document.getElementById("static2").value.trim();

    // save
    if(document.getElementById("saveId").checked)
        localStorage.setItem("id1", id1);
    else
        localStorage.removeItem("id1");

    if(document.getElementById("saveStatic").checked)
        localStorage.setItem("static1", st1);
    else
        localStorage.removeItem("static1");

    let text = "";

    if(id1 && st1) text += format(id1, st1) + "\n";
    if(id2 && st2) text += format(id2, st2) + "\n";

    text += `
Действие: ${document.getElementById("action").value}
Ранг: ${document.getElementById("rank").value}
Причина: ${document.getElementById("reason").value}
`;

    document.getElementById("out").innerText = text;
}

function copyText() {
    navigator.clipboard.writeText(document.getElementById("out").innerText);
    alert("Скопировано");
}

</script>

</body>
</html>