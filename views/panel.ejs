<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Кадровая система</title>

<style>
body{
    margin:0;
    font-family:Arial;
    background:linear-gradient(135deg,#0b1020,#121a2a);
    color:#fff;
    display:flex;
    justify-content:center;
}

.box{
    width:850px;
    margin:40px;
    background:rgba(18,22,35,0.85);
    padding:24px;
    border-radius:16px;
    backdrop-filter:blur(12px);
    box-shadow:0 10px 30px rgba(0,0,0,0.6);
}

/* ---------- LOADING ---------- */
#loadingScreen{
    position:fixed;
    top:0;left:0;
    width:100%;height:100%;
    background:#0b1020;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    z-index:999;
}

.bar{
    width:220px;
    height:6px;
    background:#1f2a44;
    border-radius:10px;
    overflow:hidden;
    margin-top:10px;
}

.fill{
    width:0%;
    height:100%;
    background:#4f6ef7;
    animation:load 2s forwards;
}

@keyframes load{
    to{width:100%}
}

.hidden{
    display:none;
}

/* ---------- UI ---------- */
h2{
    text-align:center;
    color:#cfd8ff;
}

select,input,button{
    width:100%;
    padding:12px;
    margin-top:10px;
    border:none;
    border-radius:10px;
    background:#121a2a;
    color:#fff;
}

button{
    background:linear-gradient(90deg,#2c3e66,#3b4d7a);
    cursor:pointer;
    transition:.2s;
}

button:hover{
    transform:scale(1.02);
}

#out{
    margin-top:15px;
    background:#0f1525;
    padding:12px;
    border-radius:10px;
    white-space:pre-wrap;
}

/* ---------- ONLINE ---------- */
.online{
    margin-top:20px;
    text-align:center;
    color:#9fb3ff;
}
</style>

</head>
<body>

<!-- LOADING -->
<div id="loadingScreen">
    <div>Загрузка системы...</div>
    <div class="bar"><div class="fill"></div></div>
</div>

<div class="box hidden" id="app">

<h2>Кадровая система</h2>

<!-- ВЫБОР РАЗДЕЛА -->
<select id="section" onchange="switchForm()">
    <option value="">Выберите раздел</option>
    <option value="ka">Кадровый аудит</option>
    <option value="spec">Отчёт спецухи</option>
</select>

<!-- ===== КАДРОВЫЙ АУДИТ ===== -->
<div id="kaForm" style="display:none">

<input id="id1" placeholder="Discord ID (свой)">
<input id="st1" placeholder="Static (свой)">
<input id="id2" placeholder="Discord ID (другой)">
<input id="st2" placeholder="Static (другой)">

<select id="action">
<option>Повышение</option>
<option>Понижение</option>
<option>Увольнение</option>
<option>Назначение</option>
</select>

<input id="reason" placeholder="Причина">

</div>

<!-- ===== СПЕЦУХА ===== -->
<div id="specForm" style="display:none">

<input placeholder="Кто выдал">
<input placeholder="Кто получил">
<input placeholder="Ссылка на одобрение">
<input placeholder="Что получаете">
<input placeholder="Серийный номер">
<input placeholder="Ссылка на скриншот">

</div>

<button onclick="gen()">Сгенерировать</button>
<button onclick="copy()">Копировать</button>

<div id="out"></div>

<div class="online">
🟢 Онлайн: <span id="onlineCount">0</span>
</div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
socket.on("online",(c)=> onlineCount.textContent = c);

/* ---------- LOADING ---------- */
setTimeout(()=>{
    document.getElementById("loadingScreen").style.display="none";
    document.getElementById("app").classList.remove("hidden");
},2000);

/* ---------- SWITCH ---------- */
function switchForm(){
    let v = section.value;

    kaForm.style.display = v==="ka" ? "block" : "none";
    specForm.style.display = v==="spec" ? "block" : "none";
}

/* ---------- GENERATE ---------- */
function gen(){

    if(section.value==="ka"){
        out.textContent =
`КАДРОВЫЙ АУДИТ

<@${id1.value}> | ${st1.value}
<@${id2.value}> | ${st2.value}

Действие: ${action.value}
Причина: ${reason.value}`;
    }

    if(section.value==="spec"){
        let f = document.querySelectorAll("#specForm input");

        out.textContent =
`ОТЧЁТ СПЕЦУХИ

Выдал: ${f[0].value}
Получил: ${f[1].value}
Одобрение: ${f[2].value}
Что получаете: ${f[3].value}
Серийный номер: ${f[4].value}
Скриншот: ${f[5].value}`;
    }
}

/* ---------- COPY ---------- */
function copy(){
    navigator.clipboard.writeText(out.textContent);
    alert("Скопировано!");
}
</script>

</body>
</html>