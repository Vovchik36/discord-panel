<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Кадровая система</title>

<style>
body{
    margin:0;
    font-family:Arial;
    background:linear-gradient(135deg,#0b1020,#121a2a);
    color:#fff;
    display:flex;
    justify-content:center;
}

.box{
    width:850px;
    margin:40px;
    background:rgba(18,22,35,0.88);
    padding:24px;
    border-radius:16px;
    backdrop-filter:blur(12px);
}

/* loading */
#loadingScreen{
    position:fixed;
    inset:0;
    background:#0b1020;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    z-index:999;
}

.bar{
    width:240px;
    height:6px;
    background:#1f2a44;
    border-radius:10px;
    overflow:hidden;
    margin-top:10px;
}

.fill{
    width:0%;
    height:100%;
    background:#4f6ef7;
    animation:load 2s forwards;
}

@keyframes load{
    to{width:100%}
}

.hidden{display:none;}

/* UI */
h2{
    text-align:center;
    color:#cfd8ff;
}

select,input,button{
    width:100%;
    padding:12px;
    margin-top:10px;
    border:none;
    border-radius:10px;
    background:#121a2a;
    color:#fff;
    outline:none;
}

button{
    background:linear-gradient(90deg,#2c3e66,#3b4d7a);
    cursor:pointer;
    transition:.2s;
}

button:hover{
    transform:scale(1.02);
}

#out{
    margin-top:15px;
    background:#0f1525;
    padding:12px;
    border-radius:10px;
    white-space:pre-wrap;
}

/* online */
.online{
    margin-top:20px;
    text-align:center;
    color:#9fb3ff;
}

/* copy buttons */
.copyBtn{
    background:linear-gradient(90deg,#3b4d7a,#4f6ef7);
}
</style>

</head>
<body>

<!-- LOADING -->
<div id="loadingScreen">
    <div>Загрузка системы...</div>
    <div class="bar"><div class="fill"></div></div>
</div>

<div class="box hidden" id="app">

<h2>Кадровая система</h2>

<select id="section" onchange="switchForm()">
    <option value="">Выберите раздел</option>
    <option value="ka">Кадровый аудит</option>
    <option value="spec">Отчёт спецухи</option>
</select>

<!-- KA -->
<div id="kaForm" style="display:none">

<input id="id1" placeholder="Discord ID (свой)">
<input id="st1" placeholder="Static (свой)">
<input id="id2" placeholder="Discord ID (другой)">
<input id="st2" placeholder="Static (другой)">

<select id="rank">
<option>1 ранг</option>
<option>2 ранг</option>
<option>3 ранг</option>
<option>4 ранг</option>
<option>5 ранг</option>
<option>6 ранг</option>
<option>7 ранг</option>
<option>8 ранг</option>
<option>9 ранг</option>
<option>10 ранг</option>
<option>11 ранг</option>
<option>12 ранг</option>
<option>13 ранг</option>
<option>14 ранг</option>
<option>15 ранг</option>
</select>

<select id="action">
<option>Повышение</option>
<option>Понижение</option>
<option>Увольнение</option>
<option>Назначение</option>
</select>

<input id="reason" placeholder="Причина">

<button class="copyBtn" onclick="copyKA()">Копировать КА</button>

</div>

<!-- SPEC -->
<div id="specForm" style="display:none">

<input id="spec1" placeholder="Кто выдал (ID)">
<input id="spec2" placeholder="Кто получил (ID)">
<input placeholder="Ссылка на одобрение">
<input placeholder="Что получаете">
<input placeholder="Серийный номер">
<input placeholder="Скриншот">

<button class="copyBtn" onclick="copySPEC()">Копировать отчёт</button>

</div>

<button onclick="gen()">Сгенерировать</button>

<div id="out"></div>

<div class="online">
🟢 Онлайн: <span id="onlineCount">0</span>
</div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
socket.on("online",(c)=> onlineCount.textContent = c);

/* loading */
setTimeout(()=>{
    loadingScreen.style.display="none";
    app.classList.remove("hidden");
},2000);

/* switch */
function switchForm(){
    kaForm.style.display = section.value==="ka" ? "block" : "none";
    specForm.style.display = section.value==="spec" ? "block" : "none";
}

/* generate */
function gen(){

    if(section.value==="ka"){
        out.textContent =


<@${id1.value}> | ${st1.value}
<@${id2.value}> | ${st2.value}

Ранг: ${rank.value}
Действие: ${action.value}
Причина: ${reason.value}`;
    }

    if(section.value==="spec"){
        out.textContent =
`ОТЧЁТ СПЕЦУХИ

<@${spec1.value}> | -
<@${spec2.value}> | -

Одобрение: ${document.querySelectorAll("#specForm input")[2].value}
Что получаете: ${document.querySelectorAll("#specForm input")[3].value}
Серийный номер: ${document.querySelectorAll("#specForm input")[4].value}
Скриншот: ${document.querySelectorAll("#specForm input")[5].value}`;
    }
}

/* COPY */
function copyKA(){
    navigator.clipboard.writeText(out.textContent);
    alert("КА скопирован!");
}

function copySPEC(){
    navigator.clipboard.writeText(out.textContent);
    alert("Отчёт скопирован!");
}
</script>

</body>
</html>